# Run `pnpm env:init` to create apps/web/.env.local without overwriting it.
# Product identity lives in product.config.json and is generated by product:init.
# Public values below are bundled into the browser; they are identifiers, not secrets.
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_APP_ENV=local
NEXT_PUBLIC_RELEASE_VERSION=0.1.0
NEXT_PUBLIC_SUPABASE_URL=
# Preferred public key for new Supabase projects.
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=
# Temporary legacy fallback only; Supabase plans to retire legacy anon keys by late 2026.
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# Required only when capabilities.analytics=external.
NEXT_PUBLIC_POSTHOG_KEY=
NEXT_PUBLIC_POSTHOG_HOST=https://us.i.posthog.com

# External Payment and AI variables are intentionally absent until a concrete
# reviewed server adapter defines its own contract.
